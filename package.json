    "@tiptap/vue-3": "^3.22.5",
    "culori": "^4.0.2",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^0.577.0",
    "maplibre-gl": "^5.24.0",
    "markdown-it": "^14.1.1",
    "marked": "^16.4.2",
